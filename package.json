{
  "name": "wordloom",
  "version": "0.2.0",
  "description": "Generate short, word-like lowercase names and show meanings for dictionary matches.",
  "keywords": [
    "cli",
    "cmudict",
    "dictionary",
    "name",
    "name-generator",
    "naming",
    "phonotactics",
    "pronounceable",
    "word-generator",
    "wordloom",
    "wordnet"
  ],
  "homepage": "https://github.com/nrjdalal/nameforge#readme",
  "bugs": "https://github.com/nrjdalal/nameforge/issues",
  "license": "MIT",
  "author": {
    "name": "Neeraj Dalal",
    "email": "admin@nrjdalal.com",
    "url": "https://nrjdalal.com"
  },
  "repository": "nrjdalal/nameforge",
  "funding": "https://github.com/sponsors/nrjdalal",
  "bin": {
    "wordloom": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "derive:model": "node scripts/derive-cmudict-model.mjs && oxfmt bin/cmudict-model.ts bin/wordnet-definitions.ts",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint .",
    "test": "bun test"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "lefthook": "^2.1.4",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "sort-package-json": "^3.6.1",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
